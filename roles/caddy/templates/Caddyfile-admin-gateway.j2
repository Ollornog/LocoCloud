{% if loco.tinyauth.enabled | default(false) %}
# --- Tinyauth ---
auth.{{ loco.admin.full_domain }} {
	import public
	reverse_proxy https://{{ admin_gateway_master_ip }}:443 {
		header_up Host auth.{{ loco.admin.full_domain }}
		transport http {
			tls_server_name auth.{{ loco.admin.full_domain }}
