# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
APP_URL=https://{{ pingvin_share_domain }}
{% if pingvin_share_ldap_enabled %}
# LDAP Configuration (lldap)
LDAP_ENABLED=true
LDAP_URL={{ pingvin_share_ldap_url }}
LDAP_BIND_DN={{ pingvin_share_ldap_bind_dn }}
LDAP_BIND_PASSWORD={{ pingvin_share_ldap_bind_password }}
LDAP_SEARCH_BASE={{ pingvin_share_ldap_search_base }}
LDAP_SEARCH_QUERY=(&(objectClass=person)(uid=%username%))
LDAP_ADMIN_GROUP={{ pingvin_share_ldap_admin_group }}
LDAP_FIELD_NAME_MEMBER_OF=memberOf
LDAP_FIELD_NAME_EMAIL=mail
{% endif %}
{% if pingvin_share_oidc_enabled and pingvin_share_oidc_client_id | length > 0 %}
# OIDC Configuration
OAUTH_ENABLED=true
OAUTH_PROVIDER_NAME=PocketID
OAUTH_DISCOVERY_URI={{ pingvin_share_oidc_provider_url }}/.well-known/openid-configuration
OAUTH_CLIENT_ID={{ pingvin_share_oidc_client_id }}
OAUTH_CLIENT_SECRET={{ pingvin_share_oidc_client_secret }}
OAUTH_SCOPE=openid profile email
OAUTH_USERNAME_CLAIM=preferred_username
OAUTH_ALLOW_REGISTRATION=true
OAUTH_DISABLE_PASSWORD_LOGIN=true
{% endif %}
