# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
APP_URL=https://{{ invoiceninja_domain }}
APP_KEY={{ invoiceninja_app_key }}
APP_DEBUG=false
APP_ENV=production

# Database
DB_HOST=invoiceninja-db
DB_PORT=3306
DB_DATABASE={{ invoiceninja_db_name }}
DB_USERNAME={{ invoiceninja_db_user }}
DB_PASSWORD={{ invoiceninja_db_password }}
DB_TYPE=mysql

# Queue
QUEUE_CONNECTION=database

# SMTP
{% if invoiceninja_smtp_host | default('') | length > 0 %}
MAIL_MAILER=smtp
MAIL_HOST={{ invoiceninja_smtp_host }}
MAIL_PORT={{ invoiceninja_smtp_port }}
MAIL_USERNAME={{ invoiceninja_smtp_user }}
MAIL_PASSWORD={{ invoiceninja_smtp_password }}
MAIL_FROM_NAME={{ invoiceninja_smtp_from_name }}
MAIL_FROM_ADDRESS={{ invoiceninja_smtp_from_address }}
MAIL_ENCRYPTION=tls
{% elif loco.smtp is defined %}
MAIL_MAILER=smtp
MAIL_HOST={{ loco.smtp.host }}
MAIL_PORT={{ loco.smtp.port }}
MAIL_USERNAME={{ loco.smtp.user }}
MAIL_PASSWORD={{ loco.smtp.password | default('') }}
MAIL_FROM_NAME={{ invoiceninja_smtp_from_name }}
MAIL_FROM_ADDRESS={{ loco.smtp.from }}
MAIL_ENCRYPTION={{ 'tls' if loco.smtp.starttls | default(true) else 'null' }}
{% endif %}

# E-Invoicing (ZUGFeRD)
{% if invoiceninja_enable_e_invoice %}
ENABLE_E_INVOICE=true
E_INVOICE_STANDARD={{ invoiceninja_e_invoice_standard }}
{% endif %}

# BCC for Paperless integration
{% if invoiceninja_bcc_email | default('') | length > 0 %}
POSTMARK_SECRET=
MAIL_BCC={{ invoiceninja_bcc_email }}
{% endif %}

# Trusted proxies (behind Caddy)
TRUSTED_PROXIES=*

# Logging
LOG_CHANNEL=stderr
