# ============================================
# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
# Backrest (Restic Web UI)
# Generiert: {{ ansible_facts.date_time.iso8601 }}
# ============================================

services:
  backrest:
    image: {{ backrest_image }}
    container_name: backrest
    restart: unless-stopped
    ports:
      - "{{ '127.0.0.1' if 'gateway' in server_roles else '0.0.0.0' }}:{{ backrest_port }}:9898"
    volumes:
      - {{ backrest_data_path }}/config:/config
      - {{ backrest_data_path }}/cache:/cache
{% for path in backrest_managed_paths %}
      - {{ path }}:{{ path }}:ro
{% endfor %}
    environment:
      BACKREST_DATA: /config
      BACKREST_PORT: "9898"
      XDG_CACHE_HOME: /cache
