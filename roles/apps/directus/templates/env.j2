# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
PUBLIC_URL=https://{{ directus_domain }}
SECRET={{ directus_secret }}

# Database
DB_CLIENT=pg
DB_HOST=directus-db
DB_PORT=5432
DB_DATABASE={{ directus_db_name }}
DB_USER={{ directus_db_user }}
DB_PASSWORD={{ directus_db_password }}

# Admin
{% if directus_admin_email | default('') | length > 0 %}
ADMIN_EMAIL={{ directus_admin_email }}
ADMIN_PASSWORD={{ directus_admin_password }}
{% endif %}

# OIDC via PocketID
{% if directus_oidc_enabled %}
AUTH_PROVIDERS=pocketid
AUTH_POCKETID_DRIVER=openid
AUTH_POCKETID_CLIENT_ID={{ directus_oidc_client_id }}
AUTH_POCKETID_CLIENT_SECRET={{ directus_oidc_client_secret }}
AUTH_POCKETID_ISSUER_URL={{ directus_oidc_issuer_url }}
AUTH_POCKETID_IDENTIFIER_KEY=email
AUTH_POCKETID_ALLOW_PUBLIC_REGISTRATION=true
AUTH_POCKETID_ICON=openid
AUTH_POCKETID_LABEL=PocketID
{% endif %}

LOG_LEVEL=warn
