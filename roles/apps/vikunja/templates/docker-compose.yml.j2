# Vikunja
# Generiert: {{ ansible_facts.date_time.iso8601 }}
# ============================================

services:
  vikunja:
    image: {{ vikunja_image }}
    container_name: vikunja
    restart: unless-stopped
    ports:
      - "{{ '127.0.0.1' if 'gateway' in server_roles else '0.0.0.0' }}:{{ vikunja_port }}:3456"
    volumes:
      - {{ vikunja_data_path }}/files:/app/vikunja/files
    env_file:
      - .env
    depends_on:
      vikunja-db:
        condition: service_healthy
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

  vikunja-db:
    image: {{ vikunja_db_image }}
    container_name: vikunja-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ vikunja_db_name }}
      POSTGRES_USER: {{ vikunja_db_user }}
      POSTGRES_PASSWORD: {{ vikunja_db_password }}
    volumes:
      - {{ vikunja_data_path }}/db:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vikunja_db_user }} -d {{ vikunja_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
