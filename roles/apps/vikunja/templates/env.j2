# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
VIKUNJA_SERVICE_PUBLICURL=https://{{ vikunja_domain }}
VIKUNJA_SERVICE_JWTSECRET={{ vikunja_jwt_secret }}

# Database
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_HOST=vikunja-db
VIKUNJA_DATABASE_DATABASE={{ vikunja_db_name }}
VIKUNJA_DATABASE_USER={{ vikunja_db_user }}
VIKUNJA_DATABASE_PASSWORD={{ vikunja_db_password }}

# Local auth
VIKUNJA_AUTH_LOCAL_ENABLED={{ vikunja_local_auth_enabled | string | lower }}

# OIDC via PocketID
{% if vikunja_oidc_enabled %}
VIKUNJA_AUTH_OPENID_ENABLED=true
VIKUNJA_AUTH_OPENID_PROVIDERS_{{ vikunja_oidc_provider_name | upper }}_NAME=PocketID
VIKUNJA_AUTH_OPENID_PROVIDERS_{{ vikunja_oidc_provider_name | upper }}_AUTHURL={{ vikunja_oidc_issuer_url }}
VIKUNJA_AUTH_OPENID_PROVIDERS_{{ vikunja_oidc_provider_name | upper }}_CLIENTID={{ vikunja_oidc_client_id }}
VIKUNJA_AUTH_OPENID_PROVIDERS_{{ vikunja_oidc_provider_name | upper }}_CLIENTSECRET={{ vikunja_oidc_client_secret }}
{% endif %}

# SMTP
{% if vikunja_smtp_host | default('') | length > 0 %}
VIKUNJA_MAILER_ENABLED=true
VIKUNJA_MAILER_HOST={{ vikunja_smtp_host }}
VIKUNJA_MAILER_PORT={{ vikunja_smtp_port }}
VIKUNJA_MAILER_USERNAME={{ vikunja_smtp_user }}
VIKUNJA_MAILER_PASSWORD={{ vikunja_smtp_password }}
VIKUNJA_MAILER_FROMEMAIL={{ vikunja_smtp_from }}
{% elif loco.smtp is defined %}
VIKUNJA_MAILER_ENABLED=true
VIKUNJA_MAILER_HOST={{ loco.smtp.host }}
VIKUNJA_MAILER_PORT={{ loco.smtp.port }}
VIKUNJA_MAILER_USERNAME={{ loco.smtp.user }}
VIKUNJA_MAILER_PASSWORD={{ loco.smtp.password | default('') }}
VIKUNJA_MAILER_FROMEMAIL={{ loco.smtp.from }}
{% endif %}
