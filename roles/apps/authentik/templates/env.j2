# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Database
AUTHENTIK_POSTGRESQL__HOST=authentik-db
AUTHENTIK_POSTGRESQL__NAME={{ authentik_db_name }}
AUTHENTIK_POSTGRESQL__USER={{ authentik_db_user }}
AUTHENTIK_POSTGRESQL__PASSWORD={{ authentik_db_password }}

# Redis
AUTHENTIK_REDIS__HOST=authentik-redis

# Bootstrap
{% if authentik_bootstrap_email | default('') | length > 0 %}
AUTHENTIK_BOOTSTRAP_EMAIL={{ authentik_bootstrap_email }}
AUTHENTIK_BOOTSTRAP_PASSWORD={{ authentik_bootstrap_password }}
{% endif %}

# SMTP
{% if loco.smtp is defined %}
AUTHENTIK_EMAIL__HOST={{ loco.smtp.host }}
AUTHENTIK_EMAIL__PORT={{ loco.smtp.port }}
AUTHENTIK_EMAIL__USERNAME={{ loco.smtp.user }}
AUTHENTIK_EMAIL__PASSWORD={{ loco.smtp.password | default('') }}
AUTHENTIK_EMAIL__USE_TLS={{ loco.smtp.starttls | default(true) | string | lower }}
AUTHENTIK_EMAIL__FROM={{ loco.smtp.from }}
{% endif %}
