# GENERIERT DURCH ANSIBLE — NICHT MANUELL EDITIEREN
LEAN_APP_URL=https://{{ leantime_domain }}
LEAN_SESSION_PASSWORD={{ leantime_session_password }}

# Database
LEAN_DB_HOST=leantime-db
LEAN_DB_USER={{ leantime_db_user }}
LEAN_DB_PASSWORD={{ leantime_db_password }}
LEAN_DB_DATABASE={{ leantime_db_name }}

# OIDC via PocketID
{% if leantime_oidc_enabled %}
LEAN_OIDC_ENABLE=true
LEAN_OIDC_PROVIDER_URL={{ leantime_oidc_provider_url }}
LEAN_OIDC_CLIENT_ID={{ leantime_oidc_client_id }}
LEAN_OIDC_CLIENT_SECRET={{ leantime_oidc_client_secret }}
LEAN_OIDC_CREATE_USER={{ leantime_oidc_create_user | string | lower }}
LEAN_OIDC_DEFAULT_ROLE={{ leantime_oidc_default_role }}
{% endif %}

# SMTP
{% if loco.smtp is defined %}
LEAN_EMAIL_SMTP_HOSTS={{ loco.smtp.host }}
LEAN_EMAIL_SMTP_PORT={{ loco.smtp.port }}
LEAN_EMAIL_SMTP_USERNAME={{ loco.smtp.user }}
LEAN_EMAIL_SMTP_PASSWORD={{ loco.smtp.password | default('') }}
LEAN_EMAIL_RETURN={{ loco.smtp.from }}
{% endif %}
